<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BIBLIO TECH</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/js/site.js" defer></script>
</head>
<body>
<div class="d-flex">
    <aside class="sidebar-tech d-flex flex-column p-3">
        <div class="mb-5 ps-2">
            <h4 class="fw-bold text-uppercase tracking-wider m-0" style="color: var(--tech-purple) !important;">BIBLIO TECH</h4>
            <small class="text-muted opacity-75">Admin Console v1.0</small>
        </div>

        <nav class="nav flex-column gap-2 flex-grow-1">
            <a asp-action="Books" asp-controller="User" class="nav-link nav-link-tech d-flex align-items-center gap-3">
                <i class="bi bi-book-half"></i>
                <span>LIBROS</span>
            </a>
            <a asp-action="Users" asp-controller="User" class="nav-link nav-link-tech d-flex align-items-center gap-3">
                <i class="bi bi-people-fill"></i>
                <span>USUARIOS</span>
            </a>
            <a asp-action="Loans" asp-controller="User" class="nav-link nav-link-tech d-flex align-items-center gap-3">
                <i class="bi bi-arrow-left-right"></i>
                <span>PRÉSTAMOS</span>
            </a>
        </nav>

        <div class="mt-auto border-top border-secondary pt-3 opacity-50">
            <a href="#" class="nav-link nav-link-tech small d-flex align-items-center gap-3">
                <i class="bi bi-gear"></i>
                <span>CONFIGURACIÓN</span>
            </a>
            <a href="#" class="nav-link nav-link-tech small d-flex align-items-center gap-3">
                <i class="bi bi-box-arrow-right"></i>
                <span>CERRAR SESION</span>
            </a>
        </div>
    </aside>

    <main class="main-content flex-grow-1">
        @RenderBody()
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>