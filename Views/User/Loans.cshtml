@using System.Collections
@model Proyecto.Response.ServiceResponse<IEnumerable<Loans>>

<main class="flex-grow-1" style="margin-left: 240px; padding: 2rem;">
    <div class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span style="color: var(--tech-green); font-size: 0.8rem;">●</span>
            <span class="text-uppercase tracking-wider small fw-bold" style="color: var(--tech-green);">System Live</span>
        </div>
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h1 class="fw-bold mb-1">Prestamos</h1>
            </div>
            <div class="d-flex gap-3">
                <div class="glass-card p-3 d-flex align-items-center gap-3">
                    <div class="small text-muted">Prestamos Activos</div>
                    <h3 class="fw-bold m-0" style="color: var(--tech-purple);">@Model.Data.Count()</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="glass-card p-4 border-tech-green-subtle h-100" style="border: 1px solid rgba(52, 211, 153, 0.2);">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0">Registar nuevo prestamo</h4>
                    <i class="bi bi-plus-circle-fill" style="color: var(--tech-green); font-size: 1.5rem;"></i>
                </div>

                <form asp-action="CreateLoan" method="post">
                    <div class="mb-4">
                        <label class="form-label small text-muted-custom fw-bold">SELECCIONAR USUARIO</label>
                        <div class="input-group">
                                <select name="UserId" class="form-select bg-dark border-0 text-white">
                                    @foreach (var users in ViewBag.Users as IEnumerable<Proyecto.Models.Users>)
                                    { 
                                        <option value="@users.Id">@users.Name @users.LastName</option>
                                    }
                                </select>    
                            <span class="input-group-text bg-dark border-0 text-muted"><i class="bi bi-chevron-down"></i></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small text-muted-custom fw-bold">SELECCIONAR LIBRO</label>
                        <div class="input-group">
                            <select name="BookId" class="form-select bg-dark border-0 text-white">
                                @foreach (var books in ViewBag.Books as IEnumerable<Proyecto.Models.Books>)
                                {
                                    <option value="@books.Id">@books.Name</option>
                                }
                            </select>
                            <span class="input-group-text bg-dark border-0 text-muted"><i class="bi bi-chevron-down"></i></span>
                        </div>
                    </div>
                    
                    <div class="row g-3 mb-5">
                        <div class="col-6">
                            <label class="form-label small text-muted-custom fw-bold">FECHA PRESTAMO</label>
                            <input name="Date" type="date" class="form-control bg-dark border-0 text-white small" value="2026-04-22">
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom fw-bold">FECHA ENTREGA</label>
                            <input name="DeliveryDate" type="date" class="form-control bg-dark border-0 text-white small">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-execute w-100 py-3 fw-bold text-uppercase tracking-wider">
                        GUARDAR PRESTAMO
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="glass-card p-0 overflow-hidden">
                <div class="p-4 d-flex justify-content-between align-items-center bg-dark bg-opacity-25">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-bar-chart-steps" style="color: var(--tech-purple);"></i>
                        <h5 class="fw-bold m-0">PRESTAMOS ACTUALES HASTA LA FECHA</h5>
                    </div>
                </div>

                <table class="table table-tech-v2 align-middle m-0">
                    <thead>
                        <tr>
                            <th class="ps-4">USUARIo</th>
                            <th>TITULO LIBRO</th>
                            <th>FECHA PRESTAMO</th>
                            <th>FECHA DE ENTREGA</th>
                            <th>ACCION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loan in Model.Data)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-sm bg-info bg-opacity-10 text-info">MC</div>
                                        <div>
                                            <div class="fw-bold small">@loan.User.Name @loan.User.LastName</div>
                                            <small class="text-muted" style="font-size: 0.65rem;">ID: @loan.UserId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold small">@loan.Book.Name</div>
                                    <small class="text-muted" style="font-size: 0.65rem;">ID LIBRO: @loan.BookId</small>
                                </td>
                                <td class="small">@loan.Date</td>
                                <td class="small">@loan.DeliveryDate</td>
                                <td>
                                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#infoModal-@loan.Id"><i class="bi bi-info-circle"></i></button>
                                </td>
                            </tr>
                             <div class="modal fade" id="infoModal-@loan.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 glass-card bg-dark text-white">
                                        <div class="modal-header border-secondary">
                                            <h5 class="modal-title fw-bold">Detalles del Sistema</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <div class="d-flex align-items-center gap-3 mb-4">
                                                <div class="avatar-placeholder" style="width:60px; height:60px; font-size: 2rem;"><i class="bi bi-person-fill"></i></div>
                                                <div>
                                                    <h4 class="m-0 fw-bold">@loan.User.Name @loan.User.LastName</h4>
                                                    <span class="text-muted">ID: @loan.User.Id</span>
                                                </div>
                                            </div>
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>EMAIL:</strong> @loan.User.Email</li>
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>FECHA REGISTRO:</strong> @loan.User.CreatedAt</li>
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>ROL ACTUAL:</strong> @loan.User.Status</li>
                                            </ul>
                                            <div class="modal-footer border-0">
                                                <form asp-action="ReturnLoan" method="post">
                                                    <input type="hidden" name="id" value="@loan.Id" />
                                                    <button type="submit" class="btn btn-confirm-glow">LIBERAR PRESTAMO</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
                <div class="p-3 text-center border-top border-secondary border-opacity-25">
                    <div class="btn-group gap-2">
                        <button class="btn btn-outline-secondary btn-sm px-4">Previous</button>
                        <button class="btn btn-purple btn-sm px-3">1</button>
                        <button class="btn btn-outline-secondary btn-sm px-3">2</button>
                        <button class="btn btn-outline-secondary btn-sm px-4">Next</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>