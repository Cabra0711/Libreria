@using System.Linq;
@model Proyecto.Response.ServiceResponse<IEnumerable<Users>>

<main class="flex-grow-1" style="margin-left: 240px; padding: 2rem;">
    <div class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span style="color: var(--tech-green); font-size: 0.8rem;">●</span>
            <span class="text-uppercase tracking-wider small fw-bold" style="color: var(--tech-green);">Live System Node</span>
        </div>
        <h1 class="fw-bold mb-1">Gestión de Usuarios</h1>
        <p class="text-muted small">Administra la base de datos de miembros, controla privilegios y monitorea la actividad del sistema.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-card p-0 overflow-hidden table-container-custom">
                <div class="p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold m-0">Miembros de la Biblioteca</h5>
                    <div class="d-flex gap-2">
                        <span class="badge bg-dark text-muted-custom py-2 px-3">@Model.Data.Count() EN TOTAL</span>
                        <span class="badge bg-dark py-2 px-3" style="color: var(--tech-green);">12 ACTIVOS HOY</span>
                    </div>
                </div>

                <table class="table table-tech-v2 align-middle m-0">
                    <thead>
                        <tr>
                            <th class="ps-4">USUARIO</th>
                            <th>REGISTRO</th>
                            <th>ESTADO</th>
                            <th class="text-end pe-4">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Data)
                        {
                            <tr>
                                <td data-label="USUARIO" class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-placeholder"><i class="bi bi-person-fill"></i></div>
                                        <div>
                                            <div class="fw-bold" style="color: var(--tech-purple)">@user.Name @user.LastName</div>
                                            <small class="text-muted">@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="REGISTRO" class="small">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td data-label="ESTADO"><span class="badge badge-tech badge-available">@(user.Status.ToString())</span></td>
                                <td data-label="ACCIONES" class="text-end pe-4 text-muted">
                                    <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-@user.Id"><i class="bi bi-trash"></i></button>
                                    <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#editModal-@user.Id"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#infoModal-@user.Id"><i class="bi bi-info-circle"></i></button>
                                </td>
                            </tr>

                            
                            <div class="modal fade" id="deleteModal-@user.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 glass-card bg-dark text-white">
                                        <div class="modal-header border-secondary">
                                            <h5 class="modal-title fw-bold">Confirmar Eliminación</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body text-center p-4">
                                            <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                                            <p class="mt-3">¿Estás seguro de eliminar al usuario <strong>@user.Name @user.LastName</strong>?</p>
                                        </div>
                                        <div class="modal-footer border-0">
                                            <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancelar</button>
                                            <form asp-action="Delete" asp-route-id="@user.Id" method="post">
                                                <button type="submit" class="btn btn-danger">Eliminar Registro</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="modal fade" id="editModal-@user.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 glass-card bg-dark text-white">
                                        <div class="modal-header border-secondary">
                                            <h5 class="modal-title fw-bold">Editar Usuario</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="Edit" method="post">
                                            <input type="hidden" name="Id" value="@user.Id" />
                                            <div class="modal-body p-4">
                                                <div class="mb-3">
                                                    <label class="form-label small text-muted-custom fw-bold">NOMBRE</label>
                                                    <input name="Name" class="form-control bg-dark border-secondary text-white" value="@user.Name">
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label small text-muted-custom fw-bold">APELLIDO</label>
                                                    <input name="LastName" class="form-control bg-dark border-secondary text-white" value="@user.LastName">
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label small text-muted-custom fw-bold">EMAIL</label>
                                                    <input name="Email" class="form-control bg-dark border-secondary text-white" value="@user.Email">
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label small text-muted-custom fw-bold">ESTADO</label>
                                                    <select name="Status" class="form-select bg-dark border-secondary text-white">
                                                        <option value="1">Estudiante</option>
                                                        <option value="2">Docente</option>
                                                        <option value="0">Inactivo</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0">
                                                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cerrar</button>
                                                <button type="submit" class="btn btn-confirm-glow">Guardar Cambios</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="modal fade" id="infoModal-@user.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 glass-card bg-dark text-white">
                                        <div class="modal-header border-secondary">
                                            <h5 class="modal-title fw-bold">Detalles del Sistema</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
                                            <div class="d-flex align-items-center gap-3 mb-4">
                                                <div class="avatar-placeholder" style="width:60px; height:60px; font-size: 2rem;"><i class="bi bi-person-fill"></i></div>
                                                <div>
                                                    <h4 class="m-0 fw-bold">@user.Name @user.LastName</h4>
                                                    <span class="text-muted">ID: @user.Id</span>
                                                </div>
                                            </div>
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>EMAIL:</strong> @user.Email</li>
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>FECHA REGISTRO:</strong> @user.CreatedAt</li>
                                                <li class="list-group-item bg-transparent text-white border-secondary small"><strong>ROL ACTUAL:</strong> @user.Status</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
                
                <div class="p-4 d-flex justify-content-between align-items-center border-top border-secondary opacity-75">
                    <small class="text-muted">Mostrando @Model.Data.Count() usuarios</small>
                    <div class="btn-group gap-2">
                        <button class="btn btn-outline-secondary btn-sm rounded px-3">Anterior</button>
                        <button class="btn btn-outline-secondary btn-sm rounded px-3">Siguiente</button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="glass-card p-4 border-0" style="background: #1a1a1e;">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="avatar-placeholder bg-dark" style="width: 50px; height: 50px; font-size: 1.5rem;">
                        <i class="bi bi-person-plus-fill" style="color: var(--tech-purple);"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold m-0">Registrar Nuevo</h5>
                        <small class="text-muted-custom">DATAFORM MODULE 02</small>
                    </div>
                </div>

                <form method="post" asp-action="Create">
                    <div class="mb-3">
                        <label class="form-label small text-muted-custom fw-bold">NOMBRE COMPLETO</label>
                        <input name="Name" class="form-control bg-dark border-0 text-white p-2" placeholder="Ej: Juan Pérez">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted-custom fw-bold">APELLIDO</label>
                        <input name="LastName" class="form-control bg-dark border-0 text-white p-2" placeholder="Ej: Cabrera">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted-custom fw-bold">CORREO ELECTRÓNICO</label>
                        <input name="Email" type="email" class="form-control bg-dark border-0 text-white p-2" placeholder="juan@example.com">
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="form-label small text-muted-custom fw-bold">CATEGORÍA</label>
                            <select name="Status" class="form-select bg-dark border-0 text-white p-2">
                                <option value="0">Inactivo</option>
                                <option value="1">Estudiante</option>
                                <option value="2">Docente</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted-custom fw-bold">ESTADO INICIAL</label>
                            <div class="d-flex align-items-center h-100 gap-2">
                                <span style="color: var(--tech-green);">●</span> <small>ACTIVO</small>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-confirm-glow w-100 py-3 d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-save2"></i> CONFIRMAR REGISTRO
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>
